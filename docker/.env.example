# ╔══════════════════════════════════════════════════════════════╗
# ║  Can I Trust? — Environment Variables                        ║
# ║  Copy to .env and fill in your values                        ║
# ║  NEVER commit .env to git                                    ║
# ╚══════════════════════════════════════════════════════════════╝

# ── App ─────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=False

# ── Database ─────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=can_i_trust
POSTGRES_PORT=5432

# ── Redis ────────────────────────────────────────────────────────
REDIS_PORT=6379

# ── Security ─────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_a_real_secret_key_here

# ── NewsAPI ──────────────────────────────────────────────────────
# Get free key at: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_org_key_here

# ── ML Model ─────────────────────────────────────────────────────
USE_LOCAL_MODEL=True
# Set False to use HuggingFace hosted model instead

# ── Frontend ─────────────────────────────────────────────────────
# Leave empty to use nginx proxy (recommended)
# Set to full URL if deploying frontend separately
VITE_API_URL=

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
