# ─── App Settings ───────────────────────────────────────────────
APP_NAME="Can I Trust?"
APP_VERSION="1.0.0"
DEBUG=True
ENVIRONMENT=development

# ─── Server ─────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ─── Database ───────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/can_i_trust
DATABASE_SYNC_URL=postgresql://postgres:password@localhost:5432/can_i_trust

# ─── Redis ──────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

# ─── JWT Auth ───────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── News API ───────────────────────────────────────────────────
NEWS_API_KEY=your_newsapi_org_key_here
NEWS_API_BASE_URL=https://newsapi.org/v2

# ─── ML Model ───────────────────────────────────────────────────
MODEL_PATH=./app/ml_models/fake_news_model
USE_LOCAL_MODEL=True
HF_MODEL_NAME=your-hf-username/can-i-trust-classifier

# ─── File Upload ────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=./uploads

# ─── Rate Limiting ──────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_ANALYZE=10

# ─── CORS ───────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
